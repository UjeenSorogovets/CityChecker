GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_ALLOWED_USER_ID=your-google-sub
CONTACT_EMAIL=you@example.com

# JWT signing for email/password accounts (required in production)
AUTH_JWT_SECRET=change-me-to-a-long-random-string

# Production (docker-compose.prod.yml + Caddy; TLS certs on host via Certbot)
DOMAIN=ujeen.pl
APP_PUBLIC_BASE_URL=https://ujeen.pl
