# Set DOMAIN and ACME_EMAIL in .env (see .env.example).

{
	email {$ACME_EMAIL}
}

{$DOMAIN:ujeen.pl}, www.{$DOMAIN:ujeen.pl} {
	encode gzip
	reverse_proxy api:8080 {
		header_up Host {host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-For {remote_ip}
	}
}
